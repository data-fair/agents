{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".",
    "rootDir": ".",
    "lib": ["ESNext", "DOM"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
